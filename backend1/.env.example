# Example Environment Configuration
# Copy this to backend1/.env and fill in your values

# ============================================
# MongoDB Atlas Configuration
# ============================================
# Get this from MongoDB Atlas connection string
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority

# Database name (will be created if doesn't exist)
MONGO_DB_NAME=clinora

# ============================================
# Server Configuration
# ============================================
PORT=4000
NODE_ENV=development

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# ============================================
# AI/LLM APIs (Optional but recommended)
# ============================================
# Get from https://console.groq.com/keys
GROQ_API_KEY=

# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Get from Google Cloud Console
GOOGLE_AI_KEY=

# ============================================
# Dataset Configuration (Optional)
# ============================================
# Path to CSV/JSON dataset directory
# DATASET_DIR=/path/to/dataset

# ============================================
# Additional Services (Optional)
# ============================================
# Twilio for WhatsApp integration
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
